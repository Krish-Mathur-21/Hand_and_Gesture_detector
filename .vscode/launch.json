{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Gesture Control",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/hand_gesture_light_control.exe",
            "args": [
                "--model", "model/gesture_model.pt",
                "--camera", "0",
                "--debug"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${workspaceFolder}/third_party/libtorch/lib;${env:PATH}"
                }
            ],
            "console": "integratedTerminal",
            "preLaunchTask": "CMake Build Debug"
        }
    ]
}